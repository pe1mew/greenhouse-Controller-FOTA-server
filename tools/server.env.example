# Template for .server.env — copy to the CLONE ROOT on the VPS as `.server.env`
# and fill in. Git-ignored: local deploy configuration, stays on the VPS.
WEBROOT=<absolute path the OTA vhost serves, e.g. /var/www/ota/public>
NGINX_CONF_DIR=<absolute path for ota.conf, e.g. /etc/nginx/sites-available>
