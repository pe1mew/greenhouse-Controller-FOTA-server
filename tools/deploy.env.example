# Template for .deploy.env — copy to the repo root as `.deploy.env` and fill in.
# .deploy.env is git-ignored (R-T07): NEVER commit the filled-in file.
DEPLOY_HOST=rfsee.net
DEPLOY_USER=<deploy-user>
DEPLOY_KEY=<absolute path to SSH private key, outside this repo>
REMOTE_WEBROOT=<absolute path to /hbwv/ota on the VPS>
REMOTE_CONF_DIR=<absolute path to the nginx snippets/conf.d dir>
